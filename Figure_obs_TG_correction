% Calculate tide gauge trends (1993–2022) and compare to satellite SSH
% Preallocate arrays
tg_trends = NaN(1, ns);
tg_region = strings(1, ns); % 'North' or 'South'

% Loop over sites
for si = 1:ns
    % Determine if site is North or South
    if ismember(si, south_sites)
        tg_region(si) = "South";
    else
        tg_region(si) = "North";
    end
    
    % Get site time series (annual mean DBi)
    tg_series = DBi_match(:, si); % already matches 1993–2022
    
    % Calculate linear trend in mm/year
    good = ~isnan(tg_series);
    if sum(good) > 1
        p = polyfit(ssh_years(good), tg_series(good), 1);
        tg_trends(si) = p(1); % mm/year (DBi_match is already in mm)
    end
end

