    y_full = DBi_annual(:,si);            % Full TG series for this site
    
    % Only fill NaNs
    nan_idx_full = isnan(y_full);
    if all(~nan_idx_full)
        continue  % No NaNs, skip this site
    end
    
    % Extract TG for overlap years
    y_overlap = y_full(idx_overlap);
    nan_overlap = isnan(y_overlap);
    
    % Select corresponding SSH series
    if ismember(si, south_sites)
        X_overlap = ssh_south_mm;   % Should be length(SSH_years)
    else
        X_overlap = ssh_north_mm;
    end
    
    % Training data: only valid points
    X_reg = X_overlap(~nan_overlap);
    Y_reg = y_overlap(~nan_overlap);
    
    % Apply regression only if enough valid points and X has variation
    MinPoints = 3;
    MinRange  = 1e-6;
    if length(X_reg) >= MinPoints && range(X_reg) > MinRange
        % Robust regression
        b = robustfit(X_reg, Y_reg);
        Y_pred_overlap = b(1) + b(2).*X_overlap;
        
        % Only fill NaNs in overlap years
        fill_idx = nan_overlap;
        y_overlap(fill_idx) = Y_pred_overlap(fill_idx);
        
        % Replace back into full series
        y_full(idx_overlap) = y_overlap;
    end
    
    % Fill any remaining NaNs outside overlap using nearest
    y_full = fillmissing(y_full, 'nearest');
    
    % Save filled TG
    DBi_filled(:,si) = y_full;
end

