% -------------------- Effective DOF -----------------------
function Neff = effective_dof(x, y)
% Computes effective sample size accounting for lag-1 autocorrelation
% Following Bretherton et al. (1999)

x = x(:); y = y(:);
valid = ~isnan(x) & ~isnan(y);
x = x(valid); y = y(valid);

N = numel(x);
if N < 3
    Neff = NaN;
    return
end

% Lag-1 autocorrelation
r1x = corr(x(1:end-1), x(2:end), 'rows','complete');
r1y = corr(y(1:end-1), y(2:end), 'rows','complete');

if abs(r1x*r1y) >= 1
    Neff = NaN;
    return
end

Neff = N * (1 - r1x*r1y) / (1 + r1x*r1y);

% Bound Neff
Neff = max(3, min(Neff, N));
end

function [r, p] = corr_ac(x, y)
% Correlation with autocorrelation-adjusted p-value
% Ensures scalar r (required for t-statistic)

x = x(:);
y = y(:);

valid = ~isnan(x) & ~isnan(y);
x = x(valid);
y = y(valid);

if numel(x) < 3
    r = NaN;
    p = NaN;
    return
end

R = corr(x, y, 'rows','complete');
r = R(1);   % force scalar

Neff = effective_dof(x, y);
if isnan(Neff)
    p = NaN;
    return
end

tstat = r * sqrt((Neff - 2) / (1 - r^2));
p = 2 * (1 - tcdf(abs(tstat), Neff - 2));
end
